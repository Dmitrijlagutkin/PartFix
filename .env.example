# Public base URL of the site (used for canonical URLs, sitemap, OpenGraph, JSON-LD).
# No trailing slash. MUST match the domain you register in Google Search Console.
NEXT_PUBLIC_SITE_URL=https://part-fix.vercel.app

# Google Search Console verification token (the "HTML tag" method).
# Paste ONLY the content value, e.g. from
# <meta name="google-site-verification" content="XXXX"> -> XXXX
# Leave unset if you verify via DNS (Domain property) instead.
GOOGLE_SITE_VERIFICATION=

# Web3Forms access key — powers the static contact form (no backend needed).
# Get a free key at https://web3forms.com (enter your inbox email, no account).
# It is a public routing key, safe to expose client-side. The contact form is
# inert until this is set.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=
